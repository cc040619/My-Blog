server:
  port: 7777

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/my_blog?serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf-8
    username: root
    password: 你的数据库密码
  servlet:
    multipart:
        max-file-size: 2MB
        max-request-size: 5MB

mybatis-plus:
  configuration:
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl
  global-config:
    db-config:
      logic-delete-field: delFlag
      logic-delete-value: 1
      logic-not-delete-value: 0
      id-type: auto

aliyun:
  oss:
    endpoint: 你的oss的endpoint
    bucketName: 你的oss的bucketName
    region: 你的oss的地域
    accessKeyId: 你的oss的密钥id
    accessKeySecret: 你的oss的密钥密码
